# ── Supabase (Cloud Free Tier) ──────────────────────────────────────────
# Sign up: https://supabase.com → Create project → Settings → API
# FREE: 500MB DB, 2GB bandwidth — more than enough for dev + showcase
SUPABASE_URL="https://<your-project-id>.supabase.co"
SUPABASE_PUBLISHABLE_KEY="sb_publishable_<your-anon-key>"
SUPABASE_SECRET_KEY="sb_secret_<your-service-role-key>"

# ── Neo4j AuraDB (Cloud Free Tier) ──────────────────────────────────────
# Sign up: https://console.neo4j.io → Create free instance (200MB, 50K nodes)
# FREE: 200MB, 50K nodes, 175K edges
NEO4J_URI="neo4j+s://<your-instance-id>.databases.neo4j.io"
NEO4J_USER="neo4j"
NEO4J_PASSWORD="<your-aura-password>"

# ── AI Models ──────────────────────────────────────────────────────────
# ── Ollama (local, $0) — avoids cloud AI API costs ──
# Install: https://ollama.com → ollama pull llama3.2 && ollama pull nomic-embed-text
# Handles both chat (llama3.2) and embeddings (nomic-embed-text, 768-dim)
LOCAL_LLM_URL="http://localhost:11434"

# Gemini (free tier: 60 req/min) — used for embeddings if Ollama embed fails
# https://aistudio.google.com/apikey
# GEMINI_API_KEY="AIza..."

# DeepSeek (free credits) — fallback chat provider if Ollama is down
# https://platform.deepseek.com/api_keys
# DEEPSEEK_API_KEY="sk-..."

# ── Voice (LiveKit Cloud Free Tier + Cartesia) ──────────────────────────
# LiveKit: https://cloud.livekit.io → create project (50GB/month free)
# Cartesia: https://play.cartesia.ai/keys (free credits for STT + TTS)
LIVEKIT_URL="wss://<your-project>.livekit.cloud"
LIVEKIT_API_KEY="API<your-api-key>"
LIVEKIT_SECRET="<your-secret>"
CARTESIA_API_KEY="sk-<your-cartesia-key>"
# For local dev webhook tunneling: lk dev webhook --url http://localhost:8290/livekit/webhook
# LIVEKIT_WEBHOOK_SECRET="<set-in-livekit-console>"

# ── WhatsApp (Meta API, free tier) ─────────────────────────────────────
# Meta Business account + WhatsApp sandbox: https://developers.facebook.com
# Local dev: ngrok http 3000 → set as webhook URL
WHATSAPP_API_TOKEN="EAA<your-whatsapp-token>"
WHATSAPP_PHONE_ID="<your-phone-id>"
WHATSAPP_WEBHOOK_VERIFY_TOKEN="<pick-a-verify-token>"
WHATSAPP_API_VERSION="v20.0"
WHATSAPP_WEBHOOK_URL="https://<your-ngrok>.ngrok-free.app/webhook/whatsapp"
APP_PORT="3000"

# ── Grafana Cloud (Free Tier, for Telemetry) ────────────────────────────
# Sign up: https://grafana.com → Grafana Cloud Free (50GB traces, 14d retention)
# Get OTLP endpoint: Grafana → Connections → OpenTelemetry
OTEL_EXPORTER_OTLP_ENDPOINT="https://<your-instance>.grafana.net/otlp"
OTEL_EXPORTER_OTLP_HEADERS="Authorization=Basic <base64-instanceId:token>"

# ── Upstash Redis (Cloud Free Tier) ────────────────────────────────────
# Sign up: https://upstash.com → Create Redis database (256MB free)
# FREE: 256MB, 10K commands/day — idempotency + BullMQ queues
REDIS_URL="rediss://<your-endpoint>.upstash.io:6379"

# ── Encryption (field encryption at rest) ──────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_MASTER_KEY="a1b2c3d4e5f6a7b8c9d0e1f2a3b4c5d6e7f8a9b0c1d2e3f4a5b6c7d8e9f0a1b2"
