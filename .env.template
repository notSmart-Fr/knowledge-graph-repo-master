# ── Supabase ────────────────────────────────────────────────────────────
# Get these from Project Settings → API
SUPABASE_URL="https://<project-id>.supabase.co"
SUPABASE_PUBLISHABLE_KEY="sb_publishable_<22-char-random>_<8-char-checksum>"
SUPABASE_SECRET_KEY="sb_secret_<22-char-random>_<8-char-checksum>"

# ── Neo4j AuraDB (Free Tier) ──────────────────────────────────────────
# Get these from https://console.neo4j.io after creating a free instance
NEO4J_URI="neo4j+s://<instance-id>.databases.neo4j.io"
NEO4J_USER="neo4j"
NEO4J_PASSWORD="<your-aura-password>"

# ── AI Models ──────────────────────────────────────────────────────────
# https://aistudio.google.com/apikey
GEMINI_API_KEY="AIza..."
# https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY="sk-..."

# ── Voice (LiveKit + Cartesia) ─────────────────────────────────────────
# https://cloud.livekit.io → create project
LIVEKIT_URL="wss://<project-name>.livekit.cloud"
LIVEKIT_API_KEY="API..."
LIVEKIT_SECRET="secret..."
# https://play.cartesia.ai/keys
CARTESIA_API_KEY="sk-..."

# ── WhatsApp Business API ──────────────────────────────────────────────
# https://developers.facebook.com → WhatsApp → API Setup
WHATSAPP_API_TOKEN="EAA..."
WHATSAPP_PHONE_ID="123456789..."
# Webhook verification — set this same value in Meta dashboard (WhatsApp → Configuration → Webhook)
WHATSAPP_WEBHOOK_VERIFY_TOKEN="my_verify_token"
# Meta Graph API version (latest stable: v20.0)
WHATSAPP_API_VERSION="v20.0"
# ── Dev only: fixed ngrok subdomain (claim one free static domain at dashboard.ngrok.com) ──
# Run: ngrok http 3000 --domain=my-crm-dev.ngrok-free.app
# The URL is reusable across restarts so Meta webhook config stays stable
WHATSAPP_WEBHOOK_URL="https://my-crm-dev.ngrok-free.app/webhook/whatsapp"
APP_PORT="3000"

# ── Telemetry ──────────────────────────────────────────────────────────
# https://grafana.com → Sign up for free Grafana Cloud → Tempo OTLP endpoint
OTEL_EXPORTER_OTLP_ENDPOINT="https://tempo-...grafana.net/otlp"
OTEL_EXPORTER_OTLP_HEADERS="Authorization=Basic ..."

# ── Redis (BullMQ) ─────────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ── Encryption (session encryption at rest) ────────────────────────────
SESSION_ENCRYPTION_KEY="32-byte-hex-key-here"
