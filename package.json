{
  "name": "graphrag-core",
  "version": "0.1.0",
  "description": "AI CRM — Node.js + Supabase + Neo4j + Mastra + LiveKit + pnpm",
  "type": "module",
  "packageManager": "pnpm@11.9.0",
  "scripts": {
    "check": "npx tsx scripts/ast-firewall.ts",
    "check:watch": "npx tsx scripts/ast-firewall.ts --watch",
    "check:chaos": "npx tsx scripts/ast-firewall.ts --chaos",
    "typecheck": "pnpm --filter @dtc/ai-core exec tsc --noEmit",
    "test": "pnpm --filter @dtc/ai-core exec vitest run",
    "test:watch": "pnpm --filter @dtc/ai-core exec vitest",
    "clean": "node -e \"['packages/ai-core/dist', 'tsconfig.tsbuildinfo', 'packages/ai-core/tsconfig.tsbuildinfo'].forEach(p => { try { require('fs').rmSync(p, { recursive: true, force: true }) } catch {} })\"",
    "validate": "pnpm check && pnpm test && npx tsx scripts/eval-rag.ts && npx tsx scripts/validate.ts",
    "dev:web": "pnpm --filter @dtc/web dev",
    "build:web": "pnpm --filter @dtc/web build",
    "preview:web": "pnpm --filter @dtc/web preview"
  },
  "dependencies": {
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/exporter-metrics-otlp-http": "^0.219.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.219.0",
    "@opentelemetry/sdk-metrics": "^2.8.0",
    "@opentelemetry/sdk-node": "^0.219.0",
    "chokidar": "^5.0.0",
    "ts-morph": "^28.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "typescript": "^6.0.3",
    "@types/node": "^26.0.1"
  }
}
