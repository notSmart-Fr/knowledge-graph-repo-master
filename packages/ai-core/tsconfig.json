{
  "compilerOptions": {
    "strict": true,
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "allowSyntheticDefaultImports": true,
    "lib": ["ESNext", "DOM"],
    "declaration": true
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "src/__chaos__/**", "**/__tests__/**"]
}
