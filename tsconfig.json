{
  "compilerOptions": {
    "strict": true,
    "target": "ESNext",
    "module": "Preserve",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "allowSyntheticDefaultImports": true,
    "noEmit": true,
    "jsx": "preserve",
    "lib": ["ESNext", "DOM"],
    "types": ["bun"]
  },
  "include": ["packages/**/*", "apps/widget/**/*"],
  "exclude": ["node_modules", "packages/**/node_modules", "packages/**/__chaos__", "scripts"]
}
